# Copy to .env (gitignored) OR export in your shell before launching Claude Code.
# The .mcp.json "openelis-db" server expands ${OPENELIS_DB_URL} from the environment,
# so this value must be present in the environment Claude Code runs in — a plain
# `.env` file is not auto-loaded. Set it via your shell profile, or add it to the
# `env` block of .claude/settings.local.json (also gitignored).
#
# Fill in your local OpenELIS DB credentials (the stock dev defaults ship in
# deploy/kit's compose env; the DB is bound to localhost:15432).
OPENELIS_DB_URL=postgresql://<user>:<password>@localhost:15432/clinlims
