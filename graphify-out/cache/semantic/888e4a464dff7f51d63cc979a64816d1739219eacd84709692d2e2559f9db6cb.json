{"nodes": [{"id": "docs_adr_0006_deployment_topology_doc", "label": "ADR-0006 Deployment Topology", "file_type": "document", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Marloe Uy; Artis Lindy Pinote", "contributor": null}, {"id": "docs_adr_0006_deployment_topology_m1_fully_onsite_pilot", "label": "M1 Fully Onsite Pilot", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each pilot lab runs LIS on premises with PHI staying inside the lab perimeter."}, {"id": "docs_adr_0006_deployment_topology_m3_on_prem_central_sync_spoke", "label": "M3 Own On-Prem Central Sync Spoke", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Post-pilot sync aggregates PHI on LabSolution-controlled infrastructure located in the Philippines."}, {"id": "docs_adr_0006_deployment_topology_public_cloud_m2_not_selected", "label": "M2 Public Cloud Not Selected", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Public-cloud sync is parked because it creates the highest vendor compliance burden and cloud trust boundary."}, {"id": "docs_adr_0006_deployment_topology_compliance_extra_work_gate", "label": "Compliance Extra Work Gate", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "M3 cannot be built before PIP obligations, DPA flow-downs, key custody, physical security, threat model and PIA are complete."}, {"id": "docs_adr_0006_deployment_topology_m1_known_base_change_delta", "label": "M1 Known Base Change-Control Delta", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The M3 spoke is validated as a delta on the M1 known base, not as a revalidation from zero."}, {"id": "docs_adr_0006_deployment_topology_vendor_phi_boundary_caveat", "label": "Vendor PHI Boundary Caveat", "file_type": "concept", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The M1 neither-PIC-nor-PIP conclusion holds only if support, telemetry, logs, backups, updates, and offshore access do not touch live PHI."}, {"id": "docs_adr_0006_deployment_topology_compliance_burden_rationale", "label": "Rationale: Lowest Pilot Compliance Burden", "file_type": "rationale", "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "M1 keeps sync and PIP-status compliance off the pilot critical path while preserving a later M3 sync route."}], "edges": [{"source": "docs_adr_0006_deployment_topology_doc", "target": "docs_adr_0006_deployment_topology_m1_fully_onsite_pilot", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "weight": 1.0}, {"source": "docs_adr_0006_deployment_topology_doc", "target": "docs_adr_0006_deployment_topology_m3_on_prem_central_sync_spoke", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/adr/0006-deployment-topology.md", "source_location": null, "weight": 1.0}, {"source": "docs_adr_0006_deployment_topology_doc", "target": "docs_adr_0006_deployment_topology_public_cloud_m2_not_selected", "rela